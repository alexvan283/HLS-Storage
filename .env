# HLS VIDEO RELEASE - BASIC .ENV


APP_NAME=HLSVideo
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com
APP_TIMEZONE=Asia/Ho_Chi_Minh

LOG_CHANNEL=stack
LOG_SLACK_WEBHOOK_URL=

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hlsvideo
DB_USERNAME=hlsvideo_user
DB_PASSWORD=your_db_password

CACHE_DRIVER=file
QUEUE_CONNECTION=sync

FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# License endpoints
LICENSE_VERIFY_URL=https://vlicense.hlsstorage.com/api/license/verify
LICENSE_AUTO_TRIAL_URL=https://vlicense.hlsstorage.com/api/license/auto-trial

# Localhost test support
LICENSE_LOCALHOST_DOMAIN=localhost

# Optional: leave empty, app will use server hostname
LICENSE_INSTANCE_ID=

# Shared with vLicense server
# Must be wrapped in quotes because secret contains special characters
LICENSE_SHARED_SECRET="fkE[+pS59#OQrjt}24m}NKDH{[]t(DA6G[Yu5Pa8"
